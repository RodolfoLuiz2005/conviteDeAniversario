# Variaveis publicas do Firebase usadas no frontend.
# Nao adicione senha de admin aqui. O painel usa Firebase Auth + regras do Firestore.
NODE_ENV=production
FIREBASE_API_KEY=sua_chave_firebase_aqui
FIREBASE_AUTH_DOMAIN=seu_projeto.firebaseapp.com
FIREBASE_PROJECT_ID=seu_projeto_id
FIREBASE_STORAGE_BUCKET=seu_projeto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=seu_id_mensageiro
FIREBASE_APP_ID=seu_app_id
FIREBASE_MEASUREMENT_ID=seu_measurement_id
PORT=8080
